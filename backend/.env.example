# Django Settings
DEBUG=False
SECRET_KEY=yoursecretkeyhere
ALLOWED_HOSTS=sarker.shop,www.sarker.shop,dev.sarker.shop,dev-admin.sarker.shop,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://sarker.shop,https://www.sarker.shop,https://dev.sarker.shop,https://dev-admin.sarker.shop

# Database (Production)
POSTGRES_DB=sarker_shop
POSTGRES_USER=sarker_prod_user
POSTGRES_PASSWORD=yoursecurepassword

# Email Settings (Hostinger)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=info@sarker.shop
EMAIL_HOST_PASSWORD=yoursmtppassword
DEFAULT_FROM_EMAIL=Sarker Shop <info@sarker.shop>

# Frontend
FRONTEND_URL=https://sarker.shop
DOMAIN=sarker.shop

# Redis (WebSocket & Real-time - used by Channels & Celery)
REDIS_URL=redis://redis:6379/0
