# =============================================================
# drpython-ecommerce — Environment Variables Template
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values below
#   3. NEVER commit your actual .env file (it is in .gitignore)
# =============================================================


# =============================================================
# CLIENT IDENTITY
# =============================================================
# The unique name for this client deployment.
# Used as a prefix for all Docker container names.
# Example: sarker, gurudeb, myclient
CLIENT_NAME=myclient


# =============================================================
# ENVIRONMENT MODE
# =============================================================
# Controls restart behaviour and optimizations.
#
# LOCAL DEV  → no
# SERVER     → always
RESTART_POLICY=no

# Set to 0 for local (faster restarts), 1 for server (performance)
UV_COMPILE_BYTECODE=0


# =============================================================
# DATABASE
# =============================================================
POSTGRES_DB=myshop_db
POSTGRES_USER=myshop_user
POSTGRES_PASSWORD=change_this_strong_password

# The host port PostgreSQL is exposed on.
# LOCAL: Use a non-default port to avoid conflicts (e.g. 5433)
# SERVER: 5432 is fine since Docker isolates services
DB_PORT=5433


# =============================================================
# DJANGO BACKEND
# =============================================================
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change_this_to_a_long_random_secret_key

# LOCAL: True  |  SERVER: False
DEBUG=True

# The domain this client runs on.
# LOCAL: localhost  |  SERVER: myclient.shop
DOMAIN=localhost
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost
FRONTEND_URL=http://localhost:5173


# =============================================================
# BACKEND PORTS
# =============================================================
# The host port for the Django API (daphne).
# Keep unique per client if running multiple clients on one server.
# LOCAL default: 8000  |  PROD example: 8001
BACKEND_PORT=8000

# The host port for the WebSocket service.
WS_PORT=8001


# =============================================================
# VITE / FRONTEND URLS
# =============================================================
# These are injected into the frontend build.
# LOCAL:  http://localhost:8000/api  and  ws://localhost:8001/ws
# SERVER: https://myclient.shop/api  and  wss://myclient.shop/ws
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8001/ws


# =============================================================
# GOOGLE OAUTH
# =============================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_SECRET=your_google_client_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here


# =============================================================
# FRONTEND SERVICE (most important section for new clients)
# =============================================================

# --- Path to the client frontend submodule ---
# This must match the folder you used when adding the submodule:
#   git submodule add <repo-url> frontend/<client-name>
# Example: ./frontend/sarker-shop
FRONTEND_CONTEXT=./frontend/sarker-shop

# The same path is used for hot-reload volume mounting in local dev.
FRONTEND_VOLUME=./frontend/sarker-shop

# --- LOCAL DEV mode ---
# Set FRONTEND_IMAGE to use the node image directly (no build step).
# This enables hot-reload and fast iteration.
FRONTEND_IMAGE=node:20-alpine
FRONTEND_COMMAND=sh -c "npm install && npm run dev -- --host"
FRONTEND_PORT=5173
FRONTEND_INTERNAL_PORT=5173
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# --- SERVER mode ---
# Comment out the LOCAL vars above and uncomment these instead:
# FRONTEND_IMAGE=
# FRONTEND_COMMAND=
# FRONTEND_PORT=8081
# FRONTEND_INTERNAL_PORT=80
# CHOKIDAR_USEPOLLING=false
# WATCHPACK_POLLING=false


# =============================================================
# ADMIN DASHBOARD
# =============================================================
ADMIN_PORT=5174
ADMIN_INTERNAL_PORT=5174
# SERVER mode: change port to e.g. 8082 and ADMIN_INTERNAL_PORT=80


# =============================================================
# OPTIONAL SERVICES
# =============================================================
DEFAULT_FROM_EMAIL=noreply@myclient.shop
YOUTUBE_RESOLVER_PROXY=
