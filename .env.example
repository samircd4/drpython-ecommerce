# =============================================================
# SarkerShop Environment Variables Template
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values below
#   3. NEVER commit the actual .env file (it is in .gitignore)
# =============================================================


# --- Database ---
POSTGRES_DB=sarker_shop
POSTGRES_USER=sarker_user
POSTGRES_PASSWORD=change_this_strong_password

# --- Django ---
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change_this_to_a_long_random_secret_key
DEBUG=False

# --- Domain & URLs ---
DOMAIN=sarker.shop
ALLOWED_HOSTS=sarker.shop,www.sarker.shop
CSRF_TRUSTED_ORIGINS=https://sarker.shop,https://www.sarker.shop
FRONTEND_URL=https://sarker.shop
VITE_API_URL=https://sarker.shop/api

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_SECRET=your_google_client_secret_here

# --- Docker Ports (change to separate dev & prod on same server) ---
# Default for prod: BACKEND_PORT=8001, FRONTEND_PORT=8081
# Default for dev:  BACKEND_PORT=8000, FRONTEND_PORT=9090
BACKEND_PORT=8001
FRONTEND_PORT=8081
