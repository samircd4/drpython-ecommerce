# =============================================================
# drpython-ecommerce — Environment Variables Template
# =============================================================
# INSTRUCTIONS:
#   1. cp .env.example .env
#   2. Fill in every variable — no variable should be left blank
#   3. NEVER commit your actual .env (it is in .gitignore)
#
# TWO MODES — switch by changing the values in the sections below:
#   LOCAL DEV  →  COMPOSE_PROFILES=local
#   SERVER     →  COMPOSE_PROFILES=server
# =============================================================


# =============================================================
# CLIENT IDENTITY
# =============================================================
# Unique name for this client. Used as a prefix for container names.
# Example: sarker, gurudeb, myclient
CLIENT_NAME=myclient


# =============================================================
# ENVIRONMENT MODE
# =============================================================
# LOCAL DEV  → local   (hot-reload frontend, no restart, debug on)
# SERVER     → server  (built Nginx image, always restart, debug off)
COMPOSE_PROFILES=local

# Restart policy:  no | always
RESTART_POLICY=no

# Python bytecode compilation:  0=off (fast dev restarts) | 1=on (server performance)
UV_COMPILE_BYTECODE=0


# =============================================================
# DATABASE
# =============================================================
POSTGRES_DB=myshop_db
POSTGRES_USER=myshop_user
POSTGRES_PASSWORD=change_this_strong_password

# Host port PostgreSQL is exposed on.
# LOCAL: use a custom port to avoid conflicts (e.g. 5433)
# SERVER: 5432 is fine since Docker isolates services
DB_PORT=5433


# =============================================================
# DJANGO BACKEND
# =============================================================
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change_this_to_a_long_random_secret_key

# LOCAL: True  |  SERVER: False
DEBUG=True

DOMAIN=localhost
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost
FRONTEND_URL=http://localhost:5173

# Email (optional)
DEFAULT_FROM_EMAIL=noreply@myclient.shop


# =============================================================
# BACKEND PORTS
# =============================================================
# API service port
# LOCAL: 8000  |  SERVER: e.g. 8001 (unique per client on shared VPS)
BACKEND_PORT=8000

# WebSocket service port
# LOCAL: 8001  |  SERVER: e.g. 8011
WS_PORT=8001


# =============================================================
# FRONTEND URLS (injected into Vite build and passed to frontend)
# =============================================================
# LOCAL:  http://localhost:8000   and  ws://localhost:8001/ws
# SERVER: https://myclient.shop   and  wss://myclient.shop/ws
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001/ws


# =============================================================
# GOOGLE OAUTH
# =============================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_SECRET=your_google_client_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here


# =============================================================
# FRONTEND SERVICE
# =============================================================
# Path to the frontend submodule added under frontend/<client-name>
# Must match exactly:  git submodule add <repo-url> frontend/<client-name>
FRONTEND_CONTEXT=./frontend/sarker-shop
FRONTEND_VOLUME=./frontend/sarker-shop

# Frontend port:
# LOCAL (profile=local):   5173  (Vite dev server)
# SERVER (profile=server): 8081  (Nginx built image)
FRONTEND_PORT=5173

# Admin dashboard port:
# LOCAL:   5174
# SERVER:  8082
ADMIN_PORT=5174
