# =============================================================
# drpython-ecommerce — Gurudev Client Environment
# =============================================================
# Run with:
#   docker compose --env-file .env.gurudeb -p gurudeb up -d --build
# =============================================================


# =============================================================
# CLIENT IDENTITY
# =============================================================
CLIENT_NAME=gurudeb


# =============================================================
# ENVIRONMENT MODE
# =============================================================
COMPOSE_PROFILES=server
RESTART_POLICY=always
UV_COMPILE_BYTECODE=0


# =============================================================
# DATABASE
# =============================================================
POSTGRES_DB=gurudeb_db
POSTGRES_USER=gurudeb_user
POSTGRES_PASSWORD=SP&C6jCUreQHS1VPdfy

# Unique port to avoid conflict with sarker (5433)
DB_PORT=5434


# =============================================================
# DJANGO BACKEND
# =============================================================
SECRET_KEY=gR9kXvN2mPqLwJ4nZyTbFhCeAsDuQiOp7sVlMxWrKjY5tUcBfE8dHnIo6gR9kXv=

DEBUG=False

DOMAIN=gurudebenterprise.com
ALLOWED_HOSTS=gurudebenterprise.com,www.gurudebenterprise.com,api.gurudebenterprise.com
CSRF_TRUSTED_ORIGINS=https://gurudebenterprise.com,https://api.gurudebenterprise.com
FRONTEND_URL=https://gurudebenterprise.com

# Email (optional)
DEFAULT_FROM_EMAIL=noreply@gurudeb.shop


# =============================================================
# BACKEND PORTS  (unique per client)
# =============================================================
# API service port  — sarker uses 8000
BACKEND_PORT=8002

# WebSocket service port — sarker uses 8001
WS_PORT=8012


# =============================================================
# FRONTEND URLS
# =============================================================
VITE_API_URL=https://api.gurudebenterprise.com
VITE_WS_URL=wss://api.gurudebenterprise.com/ws


# =============================================================
# GOOGLE OAUTH
# =============================================================
GOOGLE_CLIENT_ID=239653298709-9l84orij8975c0vm4ic25q9ma6sj57r2.apps.googleusercontent.com
GOOGLE_SECRET=your_google_client_secret_here
VITE_GOOGLE_CLIENT_ID=239653298709-9l84orij8975c0vm4ic25q9ma6sj57r2.apps.googleusercontent.com


# =============================================================
# FRONTEND SERVICE
# =============================================================
FRONTEND_CONTEXT=./frontend/gurudeb
FRONTEND_VOLUME=./frontend/gurudeb

# LOCAL: 5175  (unique — sarker uses 5173)
FRONTEND_PORT=5175

# Admin dashboard port — sarker uses 5174
ADMIN_PORT=5176
